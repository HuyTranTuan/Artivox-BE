// ─── Articles (Multi-language) ───────────────────────

model Article {
  id          BigInt    @id @default(autoincrement())
  slug        String    @unique
  authorId    BigInt
  coverImage  String?
  publishedAt DateTime?
  viewCount   Int       @default(0)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  author       AdminUser            @relation(fields: [authorId], references: [id])
  translations ArticleTranslation[]

  @@index([slug])
  @@index([authorId])
  @@map("articles")
}

model ArticleTranslation {
  id        BigInt   @id @default(autoincrement())
  articleId BigInt
  locale    String   @db.VarChar(10)
  title     String
  content   String
  summary   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@map("article_translations")
}

// ─── Chat System ─────────────────────────────────────

model ChatRoom {
  id         BigInt   @id @default(autoincrement())
  adminId    BigInt?
  customerId BigInt
  isActive   Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  admin    AdminUser?    @relation(fields: [adminId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])
  messages ChatMessage[]

  @@unique([adminId, customerId])
  @@index([adminId])
  @@index([customerId])
  @@map("chat_rooms")
}

model ChatMessage {
  id         BigInt            @id @default(autoincrement())
  chatRoomId BigInt
  senderType ChatMessageSender
  adminId    BigInt?
  customerId BigInt?
  content    String
  fileUrl    String?
  fileType   String?
  isRead     Boolean           @default(false)
  
  createdAt DateTime @default(now())

  chatRoom ChatRoom   @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  admin    AdminUser? @relation(fields: [adminId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])

  @@index([chatRoomId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id         BigInt           @id @default(autoincrement())
  type       NotificationType
  adminId    BigInt?
  customerId BigInt?
  title      String
  message    String
  metadata   Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  admin    AdminUser? @relation(fields: [adminId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([customerId])
  @@index([createdAt])
  @@index([isRead])
  @@map("notifications")
}

// ─── Internal Chat System (Admin to Admin/Staff) ─────

model InternalChatRoom {
  id             BigInt   @id @default(autoincrement())
  participant1Id BigInt
  participant2Id BigInt
  isActive       Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  participant1 AdminUser @relation("Participant1", fields: [participant1Id], references: [id])
  participant2 AdminUser @relation("Participant2", fields: [participant2Id], references: [id])
  messages     InternalChatMessage[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("internal_chat_rooms")
}

model InternalChatMessage {
  id         BigInt   @id @default(autoincrement())
  roomId     BigInt
  senderId   BigInt
  content    String
  fileUrl    String?
  fileType   String?
  isRead     Boolean  @default(false)
  
  createdAt DateTime @default(now())

  room   InternalChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender AdminUser        @relation("InternalSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([createdAt])
  @@map("internal_chat_messages")
}