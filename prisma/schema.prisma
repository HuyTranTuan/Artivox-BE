generator client {
  provider = "prisma-client-js"
  output   = "../generated/"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum AdminRole {
  ADMIN
  MANAGER
  STAFF
}

enum ProductType {
  MODEL
  MATERIAL
  TOOL
}

enum MaterialType {
  FDM
  SLA
}

enum MaterialUnit {
  ROLL
  BOX
}

enum ToolCategory {
  HAND_TOOL
  POST_TOOL
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUND_PENDING
  REFUNDED
}

enum DiscountType {
  FIXED
  PERCENT
}

enum ChatMessageSender {
  ADMIN
  CUSTOMER
}

// ─── Admin Users (Staff / Managers / Admins) ─────────

model AdminUser {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  password       String
  fullName       String?
  phone          String?
  slug           String    @unique
  role           AdminRole @default(STAFF)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  articles       Article[]
  orders         Order[]        @relation("AssignedAdmin")
  chatRooms      ChatRoom[]
  chatMessages   ChatMessage[]

  @@index([email])
  @@index([slug])
  @@index([role])
  @@map("admin_users")
}

// ─── Customers (E-commerce Users) ────────────────────

model Customer {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  password       String
  fullName       String?
  phone          String?
  address        String?
  slug           String    @unique
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  orders         Order[]
  cartItems      CartItem[]
  chatRooms      ChatRoom[]
  chatMessages   ChatMessage[]
  activityLogs   CustomerActivityLog[]

  @@index([email])
  @@index([slug])
  @@map("customers")
}

// ─── Catalog ─────────────────────────────────────────

model Collection {
  id             Int       @id @default(autoincrement())
  name           String    @unique
  slug           String    @unique
  description    String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  products       Product[]

  @@index([slug])
  @@map("collections")
}

model Product {
  id             Int         @id @default(autoincrement())
  name           String      @unique
  slug           String      @unique
  sku            String      @unique
  description    String?
  price          Float
  type           ProductType
  image          String?
  collectionId   Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  collection     Collection? @relation(fields: [collectionId], references: [id])
  model3D        Model3D?
  material       Material?
  tool           Tool?
  orderItems     OrderItem[]
  cartItems      CartItem[]

  @@index([collectionId])
  @@index([type])
  @@index([slug])
  @@map("products")
}

model Model3D {
  id             Int       @id @default(autoincrement())
  productId      Int       @unique
  name           String
  fileUrl        String
  thumbnail      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("model_3d")
}

model Material {
  id             Int          @id @default(autoincrement())
  productId      Int          @unique
  type           MaterialType
  color          String?
  unit           MaterialUnit
  quantity       Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("materials")
}

model Tool {
  id             Int          @id @default(autoincrement())
  productId      Int          @unique
  category       ToolCategory
  specifications String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("tools")
}

// ─── Orders & Cart ───────────────────────────────────

model Order {
  id               Int         @id @default(autoincrement())
  orderNumber      String      @unique
  customerId       Int
  assignedAdminId  Int?
  totalAmount      Float
  status           OrderStatus @default(PENDING)
  shippingAddress  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  customer         Customer    @relation(fields: [customerId], references: [id])
  assignedAdmin    AdminUser?  @relation("AssignedAdmin", fields: [assignedAdminId], references: [id])
  items            OrderItem[]

  @@index([customerId])
  @@index([assignedAdminId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id             Int       @id @default(autoincrement())
  orderId        Int
  productId      Int
  quantity       Int       @default(1)
  unitPrice      Float
  createdAt      DateTime  @default(now())

  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model CartItem {
  id             Int       @id @default(autoincrement())
  customerId     Int
  productId      Int
  quantity       Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("cart_items")
}

// ─── Discounts ───────────────────────────────────────

model Discount {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  slug           String       @unique
  type           DiscountType
  value          Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([code])
  @@index([slug])
  @@map("discounts")
}

// ─── Articles (Multi-language) ───────────────────────

model Article {
  id             Int       @id @default(autoincrement())
  slug           String    @unique
  authorId       Int
  coverImage     String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  author         AdminUser @relation(fields: [authorId], references: [id])
  translations   ArticleTranslation[]

  @@index([slug])
  @@index([authorId])
  @@map("articles")
}

model ArticleTranslation {
  id             Int       @id @default(autoincrement())
  articleId      Int
  locale         String    @db.VarChar(10)
  title          String
  content        String
  summary        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  article        Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@map("article_translations")
}

// ─── Chat System ─────────────────────────────────────

model ChatRoom {
  id             Int       @id @default(autoincrement())
  adminId        Int
  customerId     Int
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  admin          AdminUser @relation(fields: [adminId], references: [id])
  customer       Customer  @relation(fields: [customerId], references: [id])
  messages       ChatMessage[]

  @@unique([adminId, customerId])
  @@index([adminId])
  @@index([customerId])
  @@map("chat_rooms")
}

model ChatMessage {
  id             Int               @id @default(autoincrement())
  chatRoomId     Int
  senderType     ChatMessageSender
  adminId        Int?
  customerId     Int?
  content        String
  isRead         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  chatRoom       ChatRoom          @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  admin          AdminUser?        @relation(fields: [adminId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])

  @@index([chatRoomId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ─── Activity Logs ───────────────────────────────────

model CustomerActivityLog {
  id             Int       @id @default(autoincrement())
  customerId     Int
  action         String
  metadata       String?
  createdAt      DateTime  @default(now())

  customer       Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("customer_activity_logs")
}
