# ─── Server ───────────────────────────────────────────────────────────
API_PORT=3000                          # Port the Express server listens on
NODE_ENV=development                   # development | production
APP_HOST=localhost                     # Hostname (used in verify-email URL)
APP_PORT=3000                          # Same as API_PORT (used in mail links)

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/databasename
DATABASE_NAME=databasename
DATABASE_USER=                         # Postgres username
DATABASE_PASSWORD=                     # Postgres password
DATABASE_HOST=localhost(OR)127.0.0.1
DATABASE_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=                       # Random 64-char hex string
AUTH_JWT_REFRESH_SECRET=               # Different random 64-char hex string
AUTH_ACCESS_TOKEN_TTL=1h               # e.g. 15m, 1h, 24h
AUTH_REFRESH_TOKEN_TTL=7d              # e.g. 7d, 30d

# ─── Bcrypt ───────────────────────────────────────────────────────────
BCRYPT_SALT=10-12                      # Salt rounds (10-12 recommended)

# ─── CORS ─────────────────────────────────────────────────────────────
FE_URL=["http://[host]:[port]"]        # Frontend URLs (JSON array)
CORS_ORIGINS=http://[host]:[port]      # Comma-separated allowed origins

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379       # Redis connection string

# ─── Mail (Nodemailer + Gmail) ────────────────────────────────────────
MAIL_USER=youremail@gmail.com          # Gmail address to send FROM
MAIL_PASS=                             # Gmail App Password (NOT your login password)
                                       # Enable 2FA → https://myaccount.google.com/apppasswords
MAIL_SERVICE=gmail                     # nodemailer service name

# ─── AI Chat ──────────────────────────────────────────────────────────
AI_PROVIDER=groq                       # openai | groq | openrouter
AI_MODEL=                              # Override model (leave blank for default)
                                       # groq default:    llama3-8b-8192  (free)
                                       # openai default:  gpt-4-turbo-preview
                                       # openrouter:      any model slug from openrouter.ai

# Provide ONE of the following keys based on AI_PROVIDER:
AI_API_KEY=                            # Universal key override (checked first)
GROQ_API_KEY=                          # Free tier: https://console.groq.com
OPENAI_API_KEY=                        # https://platform.openai.com/api-keys
OPENROUTER_GATEWAY_API_KEY=            # https://openrouter.ai/keys
VERCEL_GATEWAY_API_KEY=                # Vercel AI Gateway key (if using gateway)

# ─── Google Drive Backup (Cron) ───────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
                                       # Path to Service Account JSON from GCP
                                       # Steps:
                                       #  1. GCP Console → IAM → Service Accounts → Create
                                       #  2. Keys tab → Add Key → JSON → Download
                                       #  3. Share Drive folder with service account email
GOOGLE_DRIVE_FOLDER_ID=1Mejbnasjncu_sageg_qaqwlqbhr_dsdmkaawqCRX
                                       # Folder ID from the Google Drive URL
