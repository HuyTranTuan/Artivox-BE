{
  "name": "artivox-be",
  "version": "1.0.0",
  "description": "Artivox Backend - 3D printing e-commerce platform",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "node scripts/prisma-generate.js",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "keywords": [
    "artivox",
    "e-commerce",
    "3d-printing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.0",
    "redis": "^5.12.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^7.8.0"
  },
  "_moduleAliases": {
    "@": "src",
    "@root": ".",
    "@controllers": "src/controllers",
    "@services": "src/services",
    "@models": "src/models",
    "@middlewares": "src/middlewares",
    "@utils": "src/utils",
    "@config": "src/config",
    "@libs": "src/libs",
    "@routes": "src/routes",
    "@validators": "src/validators"
  }
}
