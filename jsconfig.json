{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@controllers/*": ["src/controllers/*"],
      "@services/*": ["src/services/*"],
      "@middlewares/*": ["src/middlewares/*"],
      "@validators/*": ["src/validators/*"],
      "@routes/*": ["src/routes/*"],
      "@utils/*": ["src/utils/*"],
      "@config/*": ["src/config/*"],
      "@libs/*": ["src/libs/*"],
      "@models/*": ["src/models/*"],
      "@root/*": ["./*"]
    }
  },
  "include": ["src/**/*", "server.js", "scripts/**/*", "cron.service.js"],
  "exclude": ["node_modules", "generated", "backup"]
}
